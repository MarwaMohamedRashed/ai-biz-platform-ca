# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Three independent AI workloads -- each can be configured to a different
# provider and model so deprecated-model swaps are config changes, not
# code releases. Provider values: 'openai' | 'gemini' | 'claude'.
#
# 1. AUDIT  -- the ChatGPT-pillar query in the AEO audit. AUDIT_PROVIDER
#    should stay 'openai' since this measures whether the business is
#    cited *by ChatGPT specifically*. Switching to claude/gemini would
#    change what the "ChatGPT" sub-pillar score actually means.
AUDIT_PROVIDER=openai
AUDIT_MODEL=gpt-4o-mini
#
# 2. CONTENT -- description / FAQ / social-bio generation + competitor
#    sentiment analysis + own-reputation analysis. Falls back to
#    AI_PROVIDER + the matching *_MODEL env if not set.
# CONTENT_PROVIDER=openai
# CONTENT_MODEL=gpt-4o-mini
#
# 3. COACH -- AI execution coach (Pro-tier feature). Defaults to
#    gemini/gemini-3-flash for cost. Override to gemini-3.1-flash-lite
#    for cheaper, gemini-3.1-pro for better reasoning.
COACH_PROVIDER=gemini
COACH_MODEL=gemini-3-flash

# ─── Provider credentials + back-compat fallback config ───────────────────────
# AI_PROVIDER + per-provider *_MODEL are still read as fallbacks for
# CONTENT_PROVIDER/CONTENT_MODEL when the workload-specific values aren't set.
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Gemini -- 2026 model lineup: gemini-3-flash (default, successor to
# 1.5-flash), gemini-3.1-flash-lite (cheaper), gemini-3.1-pro (best
# reasoning). gemini-1.5-flash is deprecated.
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── SMS / WhatsApp (Twilio — Phase 2 only, leave blank for now) ──────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Google Business Profile API (Phase 1) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Random secret shared between Vercel Cron → Next.js route → FastAPI.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# ─── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# ─── Billing gate ─────────────────────────────────────────────────────────────
# Set to true in production once Stripe is live; keeps audits free in dev
BILLING_ENABLED=false
