# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Switch between "openai" and "gemini" without changing any code
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Gemini — used for content generation when AI_PROVIDER=gemini, AND
# always used for the AI execution coach (decoupled from AI_PROVIDER).
# 2026 model lineup: gemini-3-flash (default — successor to 1.5-flash),
# gemini-3.1-flash-lite (cheaper for high-volume), gemini-3.1-pro (best
# reasoning, higher cost). gemini-1.5-flash is deprecated.
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash

# Optional override for the AI execution coach (Pro tier feature).
# Defaults to gemini-3-flash if unset. Use gemini-3.1-flash-lite to
# reduce cost or gemini-3.1-pro to improve reasoning quality.
# COACH_MODEL=gemini-3-flash

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── SMS / WhatsApp (Twilio — Phase 2 only, leave blank for now) ──────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Google Business Profile API (Phase 1) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Random secret shared between Vercel Cron → Next.js route → FastAPI.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# ─── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# ─── Billing gate ─────────────────────────────────────────────────────────────
# Set to true in production once Stripe is live; keeps audits free in dev
BILLING_ENABLED=false
