# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Switch between "openai" and "gemini" without changing any code
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# For Gemini (Phase 2 alternative — half the cost for high-volume SMS)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── SMS / WhatsApp (Twilio — Phase 2 only, leave blank for now) ──────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Google Business Profile API (Phase 1) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Random secret shared between Vercel Cron → Next.js route → FastAPI.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# ─── App settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
